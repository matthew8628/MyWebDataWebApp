@page  //Makes the file into MVC action. must have .cshtml file extension
@model DisplayDataModel
@{
    ViewData["Title"] = "Display User Data";
}

<h1>Users</h1>

<table class="table" id="tblUsers">
    <thead>
        <tr>
            <th></th>
            <th>ID</th>
            <th>FirstName</th>
            <th>LastName</th>
            <th>MaidenName</th>
            <th>Age</th>
            <th>Gender</th>
            <th>Email</th>
            <th>Username</th>
            <th>Password</th>
            <th>Image</th>
            <th>BloodGroup</th>
            <th>Height</th>
            <th>Weight</th>
            <th>EyeColor</th>
        </tr>
    </thead>


    <tbody id="UserResults">


        @foreach (var user in Model.Users)

        // Gets the data from UsersPageModel.cs   as that is bought in at the top with @model UsersPageModel
        {

      

        <tr>
            <td>
                <a asp-page="/EditUser" asp-route-id="@user.Id" class="btn btn-primary">Edit</a>
            </td>
            <td>@user.Id</td>
            <td>@user.FirstName</td>
            <td>@user.LastName</td>
            <td>@user.MaidenName</td>
            <td>@user.Age</td>
            <td>@user.Gender</td>
            <td>@user.Email</td>
            <td>@user.Username</td>
            <td>@user.Password</td>
            <td>
                <img src="@user.Image" alt="@user.Id Image" width="100" height="120">
            </td>
            <td>@user.BloodGroup</td>
            <td>@user.Height</td>
            <td>@user.Weight</td>
            <td>@user.EyeColor</td>
            <td>
                <a asp-page="/EditUser" asp-route-id="@user.Id" class="btn btn-danger">Delete</a>
            </td>

        </tr>
      
        }
    </tbody>
</table>






