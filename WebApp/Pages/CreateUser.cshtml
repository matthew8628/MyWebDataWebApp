@page
@model WebApp.Pages.CreateUserModel
@{
    ViewData["Title"] = "Create User";
}


<link href="CSS/buttons.css" rel="stylesheet" type="text/css">
<link href="CSS/Login-Register-Forget-Pass.css" rel="stylesheet" type="text/css"> <!-- Working-->
<link href="CSS/Body.css" rel="stylesheet" type="text/css"> <!-- Working -->
<link href="wwwroot/css/_fonts.css" rel="stylesheet" type="text/css">
<link href="CSS/style.css" rel="stylesheet" type="text/css">
<link href="CSS/site.css" rel="stylesheet" type="text/css">

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700&display=swap" rel="stylesheet">


<script src="~/js/site.js"></script>


<div class="login-form pt-3 pb-3">
    <form id="formLogIn" class="mt-2"   method="post">
        <h1>Create User</h1>
        <p>Please enter the new users details.</p>
        <table class="createUserTable" id="createUser">

            <tbody>
                <tr>
                    <td><label for class="login-label">Id</label>   
                    <input asp-for="NewUser.Id" id="Id" class="form-control" placeholder aria-invalid="false"/></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.FirstName"></label>
                    <input asp-for="NewUser.FirstName" id="FirstName" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.LastName"></label>
                    <input asp-for="NewUser.LastName" id="LastName" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.MaidenName"></label>
                    <input asp-for="NewUser.MaidenName" id="MaidenName" class="form-control" placeholder aria-invalid="false" data-optional="true"/></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Age"></label>
                    <input asp-for="NewUser.Age" id="Age" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Gender"></label>
                    <input asp-for="NewUser.Gender" id="Gender" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Email"></label>
                    <input asp-for="NewUser.Email" id="Email" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Phone"></label>
                    <input asp-for="NewUser.Phone" id="Phone" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Username"></label>
                    <input asp-for="NewUser.Username" id="Username" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Password"></label>
                    <input asp-for="NewUser.Password" id="Password" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.BirthDate"></label>
                    <input asp-for="NewUser.BirthDate" id="BirthDate" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Image"></label>
                    <input asp-for="NewUser.Image" id="Image" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.BloodGroup"></label>
                    <input asp-for="NewUser.BloodGroup" id="BloodGroup" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Height"></label>
                    <input asp-for="NewUser.Height" id="Height" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.Weight"></label>
                    <input asp-for="NewUser.Weight" id="Weight" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
                <tr>
                    <td><label asp-for="NewUser.EyeColor"></label>
                    <input asp-for="NewUser.EyeColor" id="EyeColor" class="form-control" placeholder aria-invalid="false" /></td>
                </tr>
            </tbody>

        </table>
        <button class="pts-btn pts-bg-blue btn-block pts-text-neutral" type="submit" id="loginBtn">Create User</button>
    </form>
    <br />
</div>



